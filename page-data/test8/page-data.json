;\n  }\n  \n  /* Line transformer styles */\n  \n  .grvsc-has-line-highlighting > .grvsc-code > .grvsc-line::before {\n    content: ' ';\n    position: absolute;\n    width: 100%;\n  }\n  \n  .grvsc-line-diff-add::before {\n    background-color: var(--grvsc-line-diff-add-background-color, rgba(0, 255, 60, 0.2));\n  }\n  \n  .grvsc-line-diff-del::before {\n    background-color: var(--grvsc-line-diff-del-background-color, rgba(255, 0, 20, 0.2));\n  }\n  \n  .grvsc-line-number {\n    padding: 0 2px;\n    text-align: right;\n    opacity: 0.7;\n  }\n  \n</style>","fields":{"slug":"/test8/"},"frontmatter":{"title":"Test 8","date":"2021-06-20","description":"test 8","tags":["Test2"],"thumbnail":null}},"previous":{"fields":{"slug":"/test7/"},"frontmatter":{"title":"Test 7"}},"next":{"fields":{"slug":"/test9/"},"frontmatter":{"title":"Test 9"}}},"pageContext":{"id":"09dde91d-058e-5b19-b541-613c335c112b","previousPostId":"c4f69e5f-f165-5198-961f-7bd33347fa2b","nextPostId":"4606d039-1b47-5240-b0ba-b00c66e5c36c"}},"staticQueryHashes":["2260143708","2538111481","658623446","984448874"],"slicesMap":{}}