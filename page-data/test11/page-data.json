 2);\n  }\n  \n  /* Line transformer styles */\n  \n  .grvsc-has-line-highlighting > .grvsc-code > .grvsc-line::before {\n    content: ' ';\n    position: absolute;\n    width: 100%;\n  }\n  \n  .grvsc-line-diff-add::before {\n    background-color: var(--grvsc-line-diff-add-background-color, rgba(0, 255, 60, 0.2));\n  }\n  \n  .grvsc-line-diff-del::before {\n    background-color: var(--grvsc-line-diff-del-background-color, rgba(255, 0, 20, 0.2));\n  }\n  \n  .grvsc-line-number {\n    padding: 0 2px;\n    text-align: right;\n    opacity: 0.7;\n  }\n  \n</style>","fields":{"slug":"/test11/"},"frontmatter":{"title":"Test 11","date":"2021-06-20","description":"test 11","tags":["Rescript"],"thumbnail":null}},"previous":{"fields":{"slug":"/test10/"},"frontmatter":{"title":"Test 10"}},"next":{"fields":{"slug":"/test2/"},"frontmatter":{"title":"Test 2"}}},"pageContext":{"id":"e735af59-2bbc-513a-afad-0fd8835e3653","previousPostId":"7881dbd4-7546-504e-88f1-fe31c4d0f0bf","nextPostId":"9c75f7fd-f732-5fe3-88d8-3bec4ac832e9"}},"staticQueryHashes":["2260143708","2538111481","658623446","984448874"],"slicesMap":{}}