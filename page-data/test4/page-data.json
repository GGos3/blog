;\n  }\n  \n  /* Line transformer styles */\n  \n  .grvsc-has-line-highlighting > .grvsc-code > .grvsc-line::before {\n    content: ' ';\n    position: absolute;\n    width: 100%;\n  }\n  \n  .grvsc-line-diff-add::before {\n    background-color: var(--grvsc-line-diff-add-background-color, rgba(0, 255, 60, 0.2));\n  }\n  \n  .grvsc-line-diff-del::before {\n    background-color: var(--grvsc-line-diff-del-background-color, rgba(255, 0, 20, 0.2));\n  }\n  \n  .grvsc-line-number {\n    padding: 0 2px;\n    text-align: right;\n    opacity: 0.7;\n  }\n  \n</style>","fields":{"slug":"/test4/"},"frontmatter":{"title":"Test 4","date":"2021-06-20","description":"test 4","tags":["Test"],"thumbnail":null}},"previous":{"fields":{"slug":"/test3/"},"frontmatter":{"title":"Test 3"}},"next":{"fields":{"slug":"/test5/"},"frontmatter":{"title":"Test 5"}}},"pageContext":{"id":"3da1850a-0f37-535c-8755-1e947dfec5f1","previousPostId":"60f69433-51d2-5bdb-b165-56430e78f46a","nextPostId":"e503ef91-b1e2-5c20-a56c-1b9a8aeee62f"}},"staticQueryHashes":["2260143708","2538111481","658623446","984448874"],"slicesMap":{}}